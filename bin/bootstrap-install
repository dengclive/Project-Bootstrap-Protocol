#!/usr/bin/env python3
"""bootstrap-install - deterministic Claude Code configurator.

Usage:
  bootstrap-install [-c bootstrap.config.yaml] [-C projectdir]
                    [--dry-run] [--force] [--uninstall] [--print-config]
"""
import os
import sys

HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(HERE, "..", "lib"))

from installer import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
