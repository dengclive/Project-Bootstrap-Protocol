#!/usr/bin/env python3
"""run-tests - run every standalone suite and report per-suite results.

Usage:
  bin/run-tests [-k PATTERN] [-q] [--no-tree-check] [--list]

The suites are standalone scripts that call sys.exit(): each is run directly
with python3, never via pytest. Exit status is 0 only if every suite exits 0.

Why this exists rather than a shell one-liner. The habitual invocation was

    for t in tests/test_*.py; do python3 "$t"; done

which reports nothing at the end and, critically, **swallows failures**: the
loop's exit status is whatever the LAST suite returned, so a suite that fails
in the middle scrolls past and the run still looks successful. Summing the
printed "N passed" lines has the same blind spot from the other direction — a
suite that dies on an unhandled exception prints no summary line at all, so
its checks silently vanish from the total instead of registering as a failure.
Both failure modes are reported explicitly here.

The working-tree check is not incidental. Emitted hooks resolve their log path
via `${CLAUDE_PROJECT_DIR:-.}`, so a suite that runs a hook without pinning
that variable writes into the REPO instead of its fixture. That is how a
1500-line .claude/logs/hooks.log accumulated in the working tree and was
eventually committed by an over-broad `git add -A`. A suite must leave the
tree exactly as it found it; when git is available this runner fails the run
if one does not.

Three details make that guarantee actually hold — the naive version did not:

  * The snapshot uses `--ignored`, because the very path that motivated the
    check (.claude/logs/hooks.log) is gitignored, as are __pycache__/ and
    *.pyc. A plain `git status --porcelain` never reports ignored paths, so
    the check would have been blind to the exact regression it exists for.
    Suites run with PYTHONDONTWRITEBYTECODE=1 so honest bytecode caching does
    not trip the now-ignored-aware check.
  * It uses `--untracked-files=all`, so a file written into an already-present
    untracked directory is enumerated rather than collapsed to one `?? dir/`
    entry that looks identical before and after.
  * Snapshot keys keep the two-char status code and the two snapshots are
    compared by SYMMETRIC difference, so deleting or reverting an already-dirty
    file (` M f` -> ` D f`, or ` M f` -> gone) is caught rather than cancelling
    out. The one residual it cannot see is a pre-existing dirty file whose
    content a suite changes while its git status stays byte-identical (still
    ` M`); detecting that needs content hashing and is out of scope here.

When git is unavailable or this is not a checkout (tarball, container build
context, no git on PATH) the snapshot cannot be taken. That is reported LOUDLY
as "check skipped" rather than passed silently — fail-loud-not-silent means a
run where the net was never strung must not look identical to one where it
held. Use --no-tree-check to opt out explicitly and quietly.
"""
import argparse
import os
import re
import subprocess
import sys
import time

HERE = os.path.dirname(os.path.abspath(__file__))
ROOT = os.path.abspath(os.path.join(HERE, ".."))
TESTS = os.path.join(ROOT, "tests")

SUMMARY_RE = re.compile(r"(\d+)\s+passed,\s+(\d+)\s+failed")

# Under GitHub Actions, restore the per-suite log affordances the inlined loop
# used to emit (folding + inline error annotations) that a bare command loses.
GHA = os.environ.get("GITHUB_ACTIONS") == "true"


def discover(pattern=None):
    names = sorted(f for f in os.listdir(TESTS)
                   if f.startswith("test_") and f.endswith(".py"))
    if pattern:
        names = [n for n in names if pattern in n]
    return [os.path.join(TESTS, n) for n in names]


def tree_state():
    """Full porcelain snapshot, or None when git is unavailable / not a repo.

    `--ignored` so a write into a gitignored path (.claude/logs/hooks.log — the
    original leak — or __pycache__/) is visible; `--untracked-files=all` so a
    file created inside an already-untracked directory is enumerated rather than
    collapsed to one `?? dir/` entry. Each key retains the two-char status code
    (not stripped), so a deletion or revert of an already-dirty file changes the
    key instead of cancelling against its prior state under a symmetric diff.
    """
    try:
        r = subprocess.run(
            ["git", "status", "--porcelain", "--ignored",
             "--untracked-files=all"],
            cwd=ROOT, capture_output=True, text=True, timeout=30)
    except (OSError, subprocess.SubprocessError):
        return None
    if r.returncode != 0:
        return None
    return {line for line in r.stdout.splitlines() if line.strip()}


def run_one(path):
    started = time.monotonic()
    # PYTHONDONTWRITEBYTECODE: suites import lib/ and tests/ modules; without
    # this each run would drop __pycache__/*.pyc into the source tree, which the
    # now-ignored-aware tree check would (correctly) flag as pollution.
    env = dict(os.environ)
    env["PYTHONDONTWRITEBYTECODE"] = "1"
    r = subprocess.run([sys.executable, path], cwd=ROOT,
                       capture_output=True, text=True, env=env)
    elapsed = time.monotonic() - started
    out = r.stdout + r.stderr
    hits = SUMMARY_RE.findall(out)
    passed, failed = (int(hits[-1][0]), int(hits[-1][1])) if hits else (0, 0)
    return {
        "name": os.path.basename(path),
        "code": r.returncode,
        "passed": passed,
        "failed": failed,
        # A suite that dies before printing its summary is NOT a suite with
        # zero failures — flag it so it cannot be read as a clean run.
        "no_summary": not hits,
        "elapsed": elapsed,
        "output": out,
    }


def main(argv):
    ap = argparse.ArgumentParser(
        prog="run-tests", description="Run every standalone test suite.")
    ap.add_argument("-k", dest="pattern", metavar="PATTERN",
                    help="only run suites whose filename contains PATTERN")
    ap.add_argument("-q", "--quiet", action="store_true",
                    help="suppress per-check output from passing suites")
    ap.add_argument("--no-tree-check", action="store_true",
                    help="skip the working-tree pollution check")
    ap.add_argument("--list", action="store_true",
                    help="list the discovered suites and exit")
    args = ap.parse_args(argv)

    suites = discover(args.pattern)
    if not suites:
        print(f"run-tests: no suites matched {args.pattern!r}", file=sys.stderr)
        return 2
    if args.list:
        for s in suites:
            print(os.path.basename(s))
        return 0

    before = None if args.no_tree_check else tree_state()

    results = []
    for path in suites:
        res = run_one(path)
        results.append(res)
        # Fold each suite's output under Actions so a red suite is reachable
        # without scrolling a flat ~1000-line log; annotate failures inline.
        if GHA:
            print(f"::group::{res['name']}")
        if not args.quiet or res["code"] != 0:
            print(res["output"], end="" if res["output"].endswith("\n") else "\n")
        if GHA:
            print("::endgroup::")
            if res["code"] != 0:
                why = ("crashed before printing a summary"
                       if res["no_summary"] else f"{res['failed']} failing check(s)")
                print(f"::error file=tests/{res['name']}::{why} "
                      f"(exit {res['code']})")

    width = max(len(r["name"]) for r in results)
    print("\n" + "=" * (width + 34))
    print(f"{'suite'.ljust(width)}  {'checks':>8}  {'fail':>5}  {'time':>6}   status")
    print("-" * (width + 34))
    for r in results:
        if r["code"] != 0 and r["no_summary"]:
            status = f"CRASHED (exit {r['code']}, no summary)"
        elif r["code"] != 0:
            status = f"FAILED (exit {r['code']})"
        else:
            status = "ok"
        print(f"{r['name'].ljust(width)}  {r['passed']:>8}  {r['failed']:>5}  "
              f"{r['elapsed']:>5.1f}s   {status}")
    print("-" * (width + 34))

    total_p = sum(r["passed"] for r in results)
    total_f = sum(r["failed"] for r in results)
    bad = [r for r in results if r["code"] != 0]
    print(f"{len(results)} suites, {total_p} checks passed, {total_f} failed")

    rc = 0
    # Flush stdout so the stderr diagnostics below land AFTER the summary table
    # in a merged stream (CI pipes stdout and stderr separately, with no
    # ordering guarantee between the two).
    sys.stdout.flush()
    if bad:
        rc = 1
        print("\nFAILING SUITES:", file=sys.stderr)
        for r in bad:
            detail = ("crashed before printing a summary — its checks are "
                      "MISSING from the totals above"
                      if r["no_summary"] else f"{r['failed']} failing check(s)")
            print(f"  {r['name']}: exit {r['code']} — {detail}",
                  file=sys.stderr)

    # Working-tree pollution check. A None snapshot (git missing / not a repo)
    # must be reported LOUDLY, never silently skipped — otherwise a run where
    # the check never happened is indistinguishable from a verified-clean one.
    if args.no_tree_check:
        pass  # explicit, quiet opt-out
    elif before is None:
        sys.stdout.flush()
        print("\nWORKING-TREE CHECK SKIPPED: could not read git status at "
              "start (git missing, or not a git checkout). Tree pollution was "
              "NOT verified this run. Pass --no-tree-check to silence this.",
              file=sys.stderr)
    else:
        after = tree_state()
        if after is None:
            sys.stdout.flush()
            print("\nWORKING-TREE CHECK SKIPPED: git status became unavailable "
                  "mid-run; tree pollution was NOT verified this run.",
                  file=sys.stderr)
        else:
            # Symmetric difference: catches new pollution (in after, not before)
            # AND destructive changes to already-dirty state (in before, not
            # after — a deletion or revert of a file that was dirty at start).
            changed = (after - before) | (before - after)
            if changed:
                rc = 1
                print("\nWORKING TREE POLLUTED by the test run:", file=sys.stderr)
                for p in sorted(changed):
                    print(f"  {p}", file=sys.stderr)
                print("  A suite wrote into the repo instead of its fixture. "
                      "Emitted hooks resolve paths via ${CLAUDE_PROJECT_DIR:-.}"
                      " — pin CLAUDE_PROJECT_DIR (and cwd) to the fixture when "
                      "running one.", file=sys.stderr)

    if rc == 0:
        print("ALL SUITES PASSED")
    return rc


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
